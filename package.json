  "version": "1.1.0",
  "type": "module",
  "scripts": {
    "change": "changeset",
    "dev": "vite",
    "build": "tsc -b && vite build",
    "fmt": "oxfmt . --write",
    "fmt.check": "oxfmt . --check",
    "lint:js": "eslint \"**/*.{js,mjs,ts,tsx}\" --report-unused-disable-directives --max-warnings 0 --cache",
    "lint:md": "eslint \"**/*.md?(x)\" --report-unused-disable-directives --max-warnings 0 --cache --cache-strategy=content --cache-location=.eslintmdcache",
    "lint:css": "stylelint \"**/*.css\" --allow-empty-input --cache --cache-strategy=content --cache-location=.stylelintcache",
    "lint:biome": "biome lint .",
    "lint": "run-p lint:md lint:js lint:css",
    "preview": "vite preview",
    "check-types": "tsc --noEmit",
    "playwright": "playwright",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "test": "vitest"
